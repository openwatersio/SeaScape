{
  "expo": {
    "name": "SeaScape",
    "slug": "SeaScape",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "seascape",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "RYHA8UZK6Y",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Permission is necessary to display user location",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow SeaScape to record your track while the app is in the background.",
        "UIBackgroundModes": ["location"]
      },
      "bundleIdentifier": "io.openwaters.seascape"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location.",
          "isBackgroundLocationEnabled": true
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "expo-sqlite",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
