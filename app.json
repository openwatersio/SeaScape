{
  "expo": {
    "name": "Open Waters",
    "slug": "openwaters",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "openwaters",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "RYHA8UZK6Y",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Permission is necessary to display user location",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Open Waters to record your track while the app is in the background.",
        "NSLocalNetworkUsageDescription": "Open Waters discovers marine instruments on your local network to display navigation data.",
        "NSBonjourServices": [
          "_signalk-http._tcp",
          "_signalk-ws._tcp",
          "_nmea-0183._tcp"
        ],
        "UIBackgroundModes": [
          "location"
        ]
      },
      "bundleIdentifier": "io.openwaters.mobile"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      "react-native-map-link",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location.",
          "isBackgroundLocationEnabled": true
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "expo-sqlite",
      "expo-sharing",
      "react-native-map-link",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fce58c39-edee-40b0-a1a6-c9e1713cd3f7"
      }
    },
    "owner": "openwatersio",
    "android": {
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "io.openwaters.mobile"
    }
  }
}
